<Project Sdk="Dalamud.NET.Sdk/15.0.0">

  <PropertyGroup>
    <Version>0.9.11.0</Version>
    <IsPackable>false</IsPackable>

    <!-- Linux containers (our Docker CI and the official repo's Plogon builder) need this to
         build the net10.0-windows TFM; it is a no-op on Windows. -->
    <EnableWindowsTargeting>true</EnableWindowsTargeting>

    <!-- Branding -->
    <Authors>kernelcurry</Authors>
    <Company>kernelcurry</Company>
    <Copyright>Copyright © kernelcurry</Copyright>
    <PackageProjectUrl>https://github.com/kernelcurry/popotovox-plugin</PackageProjectUrl>
  </PropertyGroup>

  <!--
    Dalamud plugin manifest. Since Dalamud.NET.Sdk v14 these properties drive
    the generated manifest at build time — no separate PopotoVox.json needed.
  -->
  <PropertyGroup>
    <Name>PopotoVox</Name>
    <InternalName>PopotoVox</InternalName>
    <Author>kernelcurry</Author>
    <Punchline>Every popoto gets a voice.</Punchline>
    <!-- The closing AI sentence is required: the official repo's AI Usage Policy mandates
         disclosing AI-generated assets (icon + gallery art) in the plugin description. -->
    <Description>Hear the story, not just read it. PopotoVox voices every NPC as you play — each one cast with a unique voice, rendered entirely on your machine. Nothing leaves your PC: no cloud, no accounts, no telemetry. Scales from instant CPU voices to a GPU-powered Ultra tier that designs a voice as individual as the character. AI was used in the creation of this plugin and its artwork.</Description>
    <ApplicableVersion>any</ApplicableVersion>
    <DalamudApiLevel>15</DalamudApiLevel>
    <Tags>voice;tts;npc;audio;dialogue;accessibility</Tags>
    <CategoryTags>other</CategoryTags>
    <RepoUrl>https://github.com/kernelcurry/popotovox-plugin</RepoUrl>
    <IconUrl>https://raw.githubusercontent.com/kernelcurry/popotovox-plugin/main/images/icon.png</IconUrl>
    <ImageUrls>https://raw.githubusercontent.com/kernelcurry/popotovox-plugin/main/images/image1.png;https://raw.githubusercontent.com/kernelcurry/popotovox-plugin/main/images/image2.png;https://raw.githubusercontent.com/kernelcurry/popotovox-plugin/main/images/image3.png;https://raw.githubusercontent.com/kernelcurry/popotovox-plugin/main/images/image4.png</ImageUrls>
    <AcceptsFeedback>true</AcceptsFeedback>
  </PropertyGroup>

  <!--
    The Dalamud SDK sets TargetFramework=net10.0-windows, Platforms=x64,
    Nullable=enable, AllowUnsafeBlocks=true, and adds DalamudPackager
    automatically. It does NOT set EnableWindowsTargeting — pass it on the
    build command line (-p:EnableWindowsTargeting=true) when building from
    Linux / macOS (e.g. inside our Docker container).
  -->

  <!--
    NAudio renders our TTS PCM to the user's speakers. It is NOT a Dalamud-
    provided assembly, so DalamudPackager bundles its DLLs from the build output
    into the release zip automatically (do not mark it private/runtime-excluded).
  -->
  <!--
    The plugin itself contains NO native TTS code. Kokoro runs in the isolated
    PopotoVox.TtsHost.exe helper (built from ../tts-host) so a voice-engine fault
    can never crash the game (PRD D10). The plugin only needs NAudio (playback) and
    SharpZipLib (to extract the .tar.bz2 model).
  -->
  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="SharpZipLib" Version="1.4.2" />
  </ItemGroup>

  <!--
    Build + publish the isolated TTS helper into the plugin output as tts-host/, so
    a dev-plugin install (pointing at bin/$(Configuration)) can launch it. Runs after
    the plugin Build. (For distribution the helper bundle will move to a verified
    download; bundling it in the dev output is fine for local testing.)
  -->
  <Target Name="PublishTtsHost" AfterTargets="Build">
    <Exec Command="dotnet publish &quot;$(MSBuildProjectDirectory)\..\tts-host\PopotoVox.TtsHost.csproj&quot; -c $(Configuration) -r win-x64 --self-contained true -o &quot;$(OutDir)tts-host&quot;" />
  </Target>

  <!--
    The asset manifest and its detached signature live INSIDE the plugin binary
    (PRD §8.1 #1/#2) so they cannot be swapped at rest. The downloader trusts
    only what the embedded, signature-verified manifest names.
  -->
  <ItemGroup>
    <EmbeddedResource Include="Assets\Manifest.json" />
    <EmbeddedResource Include="Assets\Manifest.json.sig" />
  </ItemGroup>

  <!--
    Plugin icon: images/icon.png lives in the REPO and is served via repo.json's IconUrl
    (raw.githubusercontent) — that is what the installer shows. It is deliberately NOT copied into
    the build output: DalamudPackager excludes an `images` folder from the zip anyway (verified),
    and the ../images path broke the Docker build context.
  -->

  <!--
    The VoxCPM2 (Ultra) host script ships inside the plugin zip (like tts-host); its Python
    runtime and model arrive separately via the signed-manifest downloads.
  -->
  <ItemGroup>
    <None Include="..\voxcpm-host\voxcpm2_host.py" Link="voxcpm-host\voxcpm2_host.py" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
